[Unit]
Description=Navi Drone face recognition server
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/pi/navi-drone/pi_server
ExecStart=/home/pi/navi-drone/pi_server/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=3
User=pi

[Install]
WantedBy=multi-user.target
