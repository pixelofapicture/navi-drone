[Unit]
Description=Navi Drone face recognition server
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/admin/fyp/navi-drone/navi-drone/pi_server
Environment="NAVI_DRONE_CAMERA_INDEX=1"
ExecStart=/home/admin/fyp/navi-drone/navi-drone/pi_server/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=3
User=admin

[Install]
WantedBy=multi-user.target
